// Medical Store Management System - Prisma Schema
// PostgreSQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  PHARMACIST
  CASHIER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MedicineType {
  TABLET
  CAPSULE
  SYRUP
  INJECTION
  OINTMENT
  DROPS
  INHALER
  POWDER
  GEL
  CREAM
  SUPPOSITORY
  OTHER
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN_FROM_CUSTOMER
  RETURN_TO_SUPPLIER
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  EXPIRED
  DAMAGED
}

enum InvoiceStatus {
  DRAFT
  PAID
  PARTIAL
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  CHEQUE
  CREDIT
  ONLINE
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
  CANCELLED
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VIEW
  EXPORT
  IMPORT
  BACKUP
  RESTORE
}

// ============================================================
// USER MANAGEMENT
// ============================================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String     @unique
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  phone        String?
  avatar       String?
  role         UserRole   @default(CASHIER)
  roleId       String?    @map("role_id")
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  roleRef         Role?              @relation(fields: [roleId], references: [id])
  invoices        Invoice[]
  purchases       Purchase[]
  auditLogs       AuditLog[]
  stockAdjustments StockMovement[]

  @@map("users")
}

// ============================================================
// MEDICINE MANAGEMENT
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  icon        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  medicines Medicine[]

  @@map("categories")
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactPerson String? @map("contact_person")
  phone        String
  email        String?
  address      String?
  city         String?
  state        String?
  pincode      String?
  gstin        String?
  drugLicense  String?  @map("drug_license")
  isActive     Boolean  @default(true) @map("is_active")
  creditLimit  Decimal  @default(0) @db.Decimal(12, 2) @map("credit_limit")
  creditDays   Int      @default(30) @map("credit_days")
  openingBalance Decimal @default(0) @db.Decimal(12, 2) @map("opening_balance")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  purchases   Purchase[]
  medicines   Medicine[]

  @@map("suppliers")
}

model Medicine {
  id               String       @id @default(cuid())
  medicineName     String       @map("medicine_name")
  genericName      String?      @map("generic_name")
  manufacturer     String?
  categoryId       String?      @map("category_id")
  supplierId       String?      @map("supplier_id")
  medicineType     MedicineType @default(TABLET) @map("medicine_type")
  batchNumber      String?      @map("batch_number")
  expiryDate       DateTime?    @map("expiry_date")
  manufacturingDate DateTime?   @map("manufacturing_date")
  mrp              Decimal      @db.Decimal(10, 2)
  purchasePrice    Decimal      @default(0) @db.Decimal(10, 2) @map("purchase_price")
  sellingPrice     Decimal      @db.Decimal(10, 2) @map("selling_price")
  gstPercentage    Decimal      @default(12) @db.Decimal(5, 2) @map("gst_percentage")
  stockQuantity    Int          @default(0) @map("stock_quantity")
  reorderLevel     Int          @default(10) @map("reorder_level")
  maxStockLevel    Int?         @map("max_stock_level")
  barcode          String?      @unique
  rackLocation     String?      @map("rack_location")
  unit             String       @default("STRIP")
  unitsPerPack     Int          @default(10) @map("units_per_pack")
  hsnCode          String?      @map("hsn_code")
  description      String?
  imageUrl         String?      @map("image_url")
  isActive         Boolean      @default(true) @map("is_active")
  isPrescriptionRequired Boolean @default(false) @map("is_prescription_required")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  category         Category?      @relation(fields: [categoryId], references: [id])
  supplier         Supplier?      @relation(fields: [supplierId], references: [id])
  invoiceItems     InvoiceItem[]
  purchaseItems    PurchaseItem[]
  stockMovements   StockMovement[]
  expiryAlerts     ExpiryAlert[]

  @@index([medicineName])
  @@index([barcode])
  @@index([expiryDate])
  @@index([stockQuantity])
  @@map("medicines")
}

// ============================================================
// CUSTOMER MANAGEMENT
// ============================================================

model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String
  email         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  dateOfBirth   DateTime? @map("date_of_birth")
  gender        String?
  medicalHistory String?  @map("medical_history")
  allergies     String?
  doctorName    String?  @map("doctor_name")
  creditLimit   Decimal  @default(0) @db.Decimal(12, 2) @map("credit_limit")
  outstandingBalance Decimal @default(0) @db.Decimal(12, 2) @map("outstanding_balance")
  totalPurchases Decimal @default(0) @db.Decimal(12, 2) @map("total_purchases")
  loyaltyPoints Int      @default(0) @map("loyalty_points")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  invoices     Invoice[]
  transactions PaymentTransaction[]

  @@index([phone])
  @@map("customers")
}

// ============================================================
// INVOICE / BILLING
// ============================================================

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique @map("invoice_number")
  customerId      String?       @map("customer_id")
  customerName    String?       @map("customer_name")
  customerPhone   String?       @map("customer_phone")
  userId          String        @map("user_id")
  invoiceDate     DateTime      @default(now()) @map("invoice_date")
  dueDate         DateTime?     @map("due_date")
  status          InvoiceStatus @default(PAID)
  subtotal        Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2) @map("discount_amount")
  discountPercent Decimal       @default(0) @db.Decimal(5, 2) @map("discount_percent")
  taxableAmount   Decimal       @db.Decimal(12, 2) @map("taxable_amount")
  cgstAmount      Decimal       @default(0) @db.Decimal(12, 2) @map("cgst_amount")
  sgstAmount      Decimal       @default(0) @db.Decimal(12, 2) @map("sgst_amount")
  igstAmount      Decimal       @default(0) @db.Decimal(12, 2) @map("igst_amount")
  totalTax        Decimal       @default(0) @db.Decimal(12, 2) @map("total_tax")
  totalAmount     Decimal       @db.Decimal(12, 2) @map("total_amount")
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2) @map("paid_amount")
  balanceAmount   Decimal       @default(0) @db.Decimal(12, 2) @map("balance_amount")
  paymentMethod   PaymentMethod @default(CASH) @map("payment_method")
  paymentReference String?      @map("payment_reference")
  notes           String?
  prescriptionNo  String?       @map("prescription_no")
  doctorName      String?       @map("doctor_name")
  isGstInvoice    Boolean       @default(true) @map("is_gst_invoice")
  printCount      Int           @default(0) @map("print_count")
  cancelReason    String?       @map("cancel_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer         Customer?          @relation(fields: [customerId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  items            InvoiceItem[]
  transactions     PaymentTransaction[]

  @@index([invoiceDate])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String   @map("invoice_id")
  medicineId      String   @map("medicine_id")
  medicineName    String   @map("medicine_name")
  batchNumber     String?  @map("batch_number")
  expiryDate      DateTime? @map("expiry_date")
  quantity        Int
  freeQuantity    Int      @default(0) @map("free_quantity")
  mrp             Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2) @map("selling_price")
  discountPercent Decimal  @default(0) @db.Decimal(5, 2) @map("discount_percent")
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2) @map("discount_amount")
  taxableAmount   Decimal  @db.Decimal(12, 2) @map("taxable_amount")
  gstPercentage   Decimal  @db.Decimal(5, 2) @map("gst_percentage")
  cgstAmount      Decimal  @default(0) @db.Decimal(10, 2) @map("cgst_amount")
  sgstAmount      Decimal  @default(0) @db.Decimal(10, 2) @map("sgst_amount")
  totalAmount     Decimal  @db.Decimal(12, 2) @map("total_amount")
  hsnCode         String?  @map("hsn_code")
  createdAt       DateTime @default(now()) @map("created_at")

  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id])

  @@map("invoice_items")
}

// ============================================================
// PURCHASE MANAGEMENT
// ============================================================

model Purchase {
  id                String        @id @default(cuid())
  purchaseNumber    String        @unique @map("purchase_number")
  supplierId        String        @map("supplier_id")
  userId            String        @map("user_id")
  purchaseDate      DateTime      @default(now()) @map("purchase_date")
  invoiceNumber     String?       @map("invoice_number")
  invoiceDate       DateTime?     @map("invoice_date")
  status            PurchaseStatus @default(RECEIVED)
  subtotal          Decimal       @db.Decimal(12, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(12, 2) @map("discount_amount")
  taxAmount         Decimal       @default(0) @db.Decimal(12, 2) @map("tax_amount")
  totalAmount       Decimal       @db.Decimal(12, 2) @map("total_amount")
  paidAmount        Decimal       @default(0) @db.Decimal(12, 2) @map("paid_amount")
  balanceAmount     Decimal       @default(0) @db.Decimal(12, 2) @map("balance_amount")
  paymentMethod     PaymentMethod @default(CREDIT) @map("payment_method")
  paymentDueDate    DateTime?     @map("payment_due_date")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  user     User           @relation(fields: [userId], references: [id])
  items    PurchaseItem[]

  @@index([purchaseDate])
  @@map("purchases")
}

model PurchaseItem {
  id              String   @id @default(cuid())
  purchaseId      String   @map("purchase_id")
  medicineId      String   @map("medicine_id")
  medicineName    String   @map("medicine_name")
  batchNumber     String?  @map("batch_number")
  expiryDate      DateTime? @map("expiry_date")
  manufacturingDate DateTime? @map("manufacturing_date")
  quantity        Int
  freeQuantity    Int      @default(0) @map("free_quantity")
  purchasePrice   Decimal  @db.Decimal(10, 2) @map("purchase_price")
  mrp             Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2) @map("selling_price")
  gstPercentage   Decimal  @db.Decimal(5, 2) @map("gst_percentage")
  taxAmount       Decimal  @default(0) @db.Decimal(10, 2) @map("tax_amount")
  totalAmount     Decimal  @db.Decimal(12, 2) @map("total_amount")
  hsnCode         String?  @map("hsn_code")
  createdAt       DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id])

  @@map("purchase_items")
}

// ============================================================
// STOCK & INVENTORY
// ============================================================

model StockMovement {
  id           String            @id @default(cuid())
  medicineId   String            @map("medicine_id")
  movementType StockMovementType @map("movement_type")
  quantity     Int
  balanceAfter Int               @map("balance_after")
  referenceId  String?           @map("reference_id")
  referenceType String?          @map("reference_type")
  batchNumber  String?           @map("batch_number")
  notes        String?
  userId       String?           @map("user_id")
  createdAt    DateTime          @default(now()) @map("created_at")

  medicine Medicine @relation(fields: [medicineId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([medicineId])
  @@index([createdAt])
  @@map("stock_movements")
}

model ExpiryAlert {
  id          String      @id @default(cuid())
  medicineId  String      @map("medicine_id")
  expiryDate  DateTime    @map("expiry_date")
  daysToExpiry Int        @map("days_to_expiry")
  stockQty    Int         @map("stock_qty")
  status      AlertStatus @default(ACTIVE)
  acknowledgedAt DateTime? @map("acknowledged_at")
  resolvedAt  DateTime?   @map("resolved_at")
  notes       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  medicine Medicine @relation(fields: [medicineId], references: [id])

  @@index([expiryDate])
  @@index([status])
  @@map("expiry_alerts")
}

// ============================================================
// PAYMENTS
// ============================================================

model PaymentTransaction {
  id              String        @id @default(cuid())
  invoiceId       String?       @map("invoice_id")
  customerId      String?       @map("customer_id")
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  transactionRef  String?       @map("transaction_ref")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")

  invoice  Invoice?  @relation(fields: [invoiceId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("payment_transactions")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  action     AuditAction
  tableName  String?     @map("table_name")
  recordId   String?     @map("record_id")
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  description String?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([tableName])
  @@map("audit_logs")
}

// ============================================================
// SETTINGS
// ============================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  label     String?
  isPublic  Boolean  @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("settings")
}
