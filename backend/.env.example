# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/medical_store_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# App
APP_NAME="MedStore Pro"
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Logs
LOG_LEVEL=info
LOG_DIR=logs

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Pharmacy Details (for invoices)
PHARMACY_NAME="MedStore Pharmacy"
PHARMACY_ADDRESS="123 Medical Lane, Healthcare City - 400001"
PHARMACY_PHONE="+91 98765 43210"
PHARMACY_EMAIL="info@medstore.pharmacy"
PHARMACY_GSTIN="27AABCU9603R1ZX"
PHARMACY_LICENSE="DL-MH-123456"
PHARMACY_DRUG_LICENSE="20B-MH-2024-001"
